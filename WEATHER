<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IRL Weather Overlay</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background: transparent;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }

    .overlay {
      position: fixed;
      top: 18px;
      right: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 16px;
      background: rgba(18, 18, 22, 0.55);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: #fff;
      box-shadow: 0 4px 18px rgba(0,0,0,0.25);
      border: 1px solid rgba(255,255,255,0.10);
      min-width: 210px;
      user-select: none;
    }

    .left {
      display: flex;
      flex-direction: column;
      line-height: 1.05;
      min-width: 0;
    }

    .city {
      font-size: 18px;
      font-weight: 700;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 120px;
    }

    .temp {
      font-size: 30px;
      font-weight: 800;
      margin-top: 2px;
    }

    .right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      margin-left: auto;
      line-height: 1;
    }

    .label {
      font-size: 10px;
      opacity: 0.7;
      letter-spacing: 1px;
      margin-bottom: 4px;
    }

    .time {
      font-size: 28px;
      font-weight: 800;
    }

    .dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #31d158;
      box-shadow: 0 0 8px rgba(49, 209, 88, 0.9);
      margin-right: 2px;
      flex: 0 0 auto;
    }

    .status {
      position: fixed;
      bottom: 12px;
      right: 18px;
      font-size: 11px;
      color: rgba(255,255,255,0.45);
      background: rgba(0,0,0,0.18);
      padding: 3px 8px;
      border-radius: 10px;
      display: none;
    }
  </style>
</head>
<body>
  <div class="overlay" id="overlay">
    <div class="dot"></div>

    <div class="left">
      <div class="city" id="city">Ottawa</div>
      <div class="temp" id="temp">--°C</div>
    </div>

    <div class="right">
      <div class="label">TIME</div>
      <div class="time" id="time">--:--</div>
    </div>
  </div>

  <div class="status" id="status"></div>

  <script>
    const FALLBACK = {
      city: "Ottawa",
      latitude: 45.4215,
      longitude: -75.6972,
      timezone: "America/Toronto"
    };

    const cityEl = document.getElementById("city");
    const tempEl = document.getElementById("temp");
    const timeEl = document.getElementById("time");
    const statusEl = document.getElementById("status");

    let currentTimezone = FALLBACK.timezone;
    let lastCoordsKey = "";
    let lastGoodTemp = null;
    let usingFallback = false;

    function setStatus(text, show = true) {
      statusEl.textContent = text;
      statusEl.style.display = show ? "block" : "none";
    }

    function updateClock() {
      try {
        const now = new Date();
        const text = new Intl.DateTimeFormat("en-CA", {
          hour: "2-digit",
          minute: "2-digit",
          hour12: false,
          timeZone: currentTimezone || FALLBACK.timezone
        }).format(now);
        timeEl.textContent = text;
      } catch {
        const now = new Date();
        const hh = String(now.getHours()).padStart(2, "0");
        const mm = String(now.getMinutes()).padStart(2, "0");
        timeEl.textContent = `${hh}:${mm}`;
      }
    }

    async function reverseCity(lat, lon) {
      try {
        const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lon)}&zoom=10&addressdetails=1`;
        const res = await fetch(url, {
          headers: {
            "Accept": "application/json"
          },
          cache: "no-store"
        });
        if (!res.ok) throw new Error("reverse geocode failed");
        const data = await res.json();
        const addr = data.address || {};
        return (
          addr.city ||
          addr.town ||
          addr.village ||
          addr.municipality ||
          addr.county ||
          FALLBACK.city
        );
      } catch {
        return FALLBACK.city;
      }
    }

    async function fetchWeather(lat, lon) {
      const url =
        `https://api.open-meteo.com/v1/forecast?latitude=${encodeURIComponent(lat)}` +
        `&longitude=${encodeURIComponent(lon)}` +
        `&current=temperature_2m` +
        `&timezone=auto` +
        `&forecast_days=1`;

      const res = await fetch(url, { cache: "no-store" });
      if (!res.ok) throw new Error("weather fetch failed");
      return await res.json();
    }

    async function applyWeather(lat, lon, cityName) {
      const data = await fetchWeather(lat, lon);

      const temp = data?.current?.temperature_2m;
      const timezone = data?.timezone || FALLBACK.timezone;

      if (typeof temp !== "number") {
        throw new Error("invalid temperature");
      }

      currentTimezone = timezone;
      cityEl.textContent = cityName || FALLBACK.city;
      tempEl.textContent = `${Math.round(temp)}°C`;
      lastGoodTemp = temp;
      updateClock();
      setStatus(usingFallback ? "Fallback: Ottawa" : "Live weather", false);
    }

    async function loadByCoords(lat, lon) {
      const roundedKey = `${lat.toFixed(3)},${lon.toFixed(3)}`;
      const cityName = await reverseCity(lat, lon);
      lastCoordsKey = roundedKey;
      await applyWeather(lat, lon, cityName);
    }

    async function loadFallback() {
      usingFallback = true;
      await applyWeather(FALLBACK.latitude, FALLBACK.longitude, FALLBACK.city);
    }

    function getCurrentPositionPromise(options) {
      return new Promise((resolve, reject) => {
        if (!navigator.geolocation) {
          reject(new Error("geolocation unavailable"));
          return;
        }
        navigator.geolocation.getCurrentPosition(resolve, reject, options);
      });
    }

    async function refreshAll() {
      try {
        setStatus("Updating...", true);

        const pos = await getCurrentPositionPromise({
          enableHighAccuracy: true,
          timeout: 10000,
          maximumAge: 60000
        });

        usingFallback = false;
        const lat = pos.coords.latitude;
        const lon = pos.coords.longitude;
        await loadByCoords(lat, lon);
      } catch (err) {
        try {
          await loadFallback();
        } catch {
          if (lastGoodTemp !== null) {
            tempEl.textContent = `${Math.round(lastGoodTemp)}°C`;
          }
          cityEl.textContent = FALLBACK.city;
          setStatus("Weather update failed", true);
        }
      }
    }

    updateClock();
    setInterval(updateClock, 1000);

    refreshAll();
    setInterval(refreshAll, 120000);
  </script>
</body>
</html>
